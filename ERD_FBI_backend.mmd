      uuid id PK
      uuid kpi_id FK
      uuid academic_year_id FK
      uuid semester_id FK
      uuid direction_id FK
      decimal target_value
      uuid owner_role_id FK
    }
    kpi_values {
      uuid id PK
      uuid kpi_id FK
      uuid academic_year_id FK
      uuid semester_id FK
      uuid direction_id FK
      uuid group_id FK
      decimal fact_value
      string status
      datetime calculated_at
    }
    risk_alerts {
      uuid id PK
      string alert_type
      string severity
      string title
      string description
      uuid direction_id FK
      uuid group_id FK
      uuid discipline_id FK
      uuid semester_id FK
      bool is_resolved
      datetime created_at
    }
    calendar_events {
      uuid id PK
      string title
      string event_type
      datetime starts_at
      datetime ends_at
      uuid direction_id FK
      uuid group_id FK
      uuid created_by FK
    }
    calendar_notes {
      uuid id PK
      date note_date
      uuid author_person_id FK
      string text
      bool is_private
      datetime created_at
      datetime updated_at
    }
    documents {
      uuid id PK
      string doc_type
      string title
      string file_url
      string version
      uuid owner_role_id FK
      uuid signed_by_person_id FK
      string status
    }
    document_access_rules {
      uuid id PK
      uuid document_id FK
      uuid role_id FK
      bool can_read
      bool can_edit
      bool can_sign
    }
    notifications {
      uuid id PK
      uuid recipient_person_id FK
      string type
      string title
      string body
      bool is_read
      datetime created_at
      datetime read_at
    }
    audit_log {
      uuid id PK
      uuid actor_person_id FK
      string action
      string entity_name
      uuid entity_id
      json old_value_json
      json new_value_json
      string source
      datetime created_at
    }

