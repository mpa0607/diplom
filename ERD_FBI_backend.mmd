erDiagram
    users {
      uuid id PK
      string email UK
      string password_hash
      bool is_active
      datetime last_login_at
    }
    persons {
      uuid id PK
      uuid user_id FK
      string last_name
      string first_name
      string middle_name
      date birth_date
      string phone
      string status
    }
    roles {
      uuid id PK
      string code UK
      string name
      string description
    }
    role_assignments {
      uuid id PK
      uuid person_id FK
      uuid role_id FK
      uuid assigned_by FK
      date starts_at
      date ends_at
      bool is_primary
    }
    role_hierarchy {
      uuid id PK
      uuid parent_role_id FK
      uuid child_role_id FK
      bool can_assign
      bool can_view_docs
      bool can_create_tasks
    }
    directions {
      uuid id PK
      string code UK
      string name
      string degree_level
      int study_years
    }
    education_programs {
      uuid id PK
      uuid direction_id FK
      string code UK
      string name
      int start_year
      int end_year
      bool is_active
    }
    academic_years {
      uuid id PK
      string label UK
      int year_start
      int year_end
      bool is_current
    }
    semesters {
      uuid id PK
      uuid academic_year_id FK
      int term_no
      string name
      date starts_at
      date ends_at
    }
    departments {
      uuid id PK
      string code UK
      string name
      uuid head_person_id FK
    }
    groups {
      uuid id PK
      string code UK
      uuid education_program_id FK
      int course_no
      int intake_year
      uuid curator_person_id FK
      bool is_active
    }
    students {
      uuid id PK
      uuid person_id FK
      string student_code UK
      string record_book_no UK
      uuid group_id FK
      string status
    }
    teachers {
      uuid id PK
      uuid person_id FK
      uuid department_id FK
      string position
      decimal rate
      bool is_active
    }
    curriculums {
      uuid id PK
      uuid education_program_id FK
      string version
      date approved_at
      bool is_active
    }
    disciplines {
      uuid id PK
      string code UK
      string name
      uuid department_id FK
      string control_type
      int hours_total
    }
