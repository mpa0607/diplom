      uuid id PK
      uuid teacher_id FK
      uuid group_id FK
      uuid discipline_id FK
      uuid semester_id FK
      string role_in_course
      int hours_assigned
    }
    grade_records {
      uuid id PK
      uuid student_id FK
      uuid discipline_id FK
      uuid semester_id FK
      decimal grade_value
      string grade_text
      bool is_passed
      int attempt_no
    }
    academic_debts {
      uuid id PK
      uuid student_id FK
      uuid discipline_id FK
      uuid semester_id FK
      string debt_type
      date opened_at
      date closed_at
      string status
    }
    student_risk_scores {
      uuid id PK
      uuid student_id FK
      uuid semester_id FK
      int risk_level
      decimal risk_score
      json factors_json
      datetime calculated_at
    }
    group_metrics {
      uuid id PK
      uuid group_id FK
      uuid semester_id FK
      decimal avg_grade
      decimal debt_rate_pct
      decimal expulsion_rate_pct
      datetime calculated_at
    }
    enrollment_movements {
      uuid id PK
      uuid student_id FK
      string movement_type
      date movement_date
      string order_no
      string reason
      uuid direction_id FK
    }
    kpi_definitions {
      uuid id PK
      string code UK
      string name
      string unit
      bool is_higher_better
    }
